# .env.traefik.example
#
# Copy this file to .env and fill in your values before running:
#   docker compose -f docker-compose.traefik.yml up -d
#
# ─── Public setup (VPS / server with internet access) ───────────────────────
# Requires public domain names and open ports 80 + 443.
# Traefik obtains TLS certificates from Let's Encrypt automatically.
# Set ACME_EMAIL and use public domain names for OPENCLAW_DOMAIN and CLAWMETRY_DOMAIN.
#
# ─── Internal setup (home lab / LAN / no public access) ─────────────────────
# Leave ACME_EMAIL empty and adjust docker-compose.traefik.yml as described in
# docs/guide/traefik.md (remove TLS/HTTPS config, switch to plain HTTP entry point).
# Traefik routes plain HTTP only — no TLS, no public domain needed.
# Use local hostnames (e.g. via /etc/hosts) or the server's LAN IP address.

# Email address for Let's Encrypt certificate registration
# Required for a public setup; leave empty for an internal (HTTP-only) setup
ACME_EMAIL=your@example.com

# Hostname for the OpenClaw gateway
# Public:   fully-qualified domain name pointing to this server's public IP
# Internal: local hostname (add to /etc/hosts) or the server's LAN IP
OPENCLAW_DOMAIN=openclaw.example.com

# Hostname for the ClawMetry dashboard
# Public:   fully-qualified domain name pointing to this server's public IP
# Internal: local hostname (add to /etc/hosts) or the server's LAN IP
CLAWMETRY_DOMAIN=clawmetry.example.com

# Optional: your display name shown in the ClawMetry Flow tab
OPENCLAW_USER=
